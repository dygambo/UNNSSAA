generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MEMBER
  ADMIN
  SUPERADMIN
}

enum RecordStatus {
  PENDING
  ACTIVE
  IN_REVIEW
  RESOLVED
  ARCHIVED
}

model User {
  id             String              @id @default(cuid())
  fullName       String
  email          String              @unique
  passwordHash   String
  role           Role                @default(MEMBER)
  isActive       Boolean             @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  memberProfile   MemberProfile?
  refreshTokens   RefreshToken[]
  eventRSVPs      EventRegistration[]
  donations       Donation[]
  grievances      Grievance[]
  createdEvents   Event[]             @relation("EventCreator")
  createdCareers  CareerOpportunity[] @relation("CareerCreator")
  mentorProfile   MentorProfile?
  auditLogs       AuditLog[]
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  tokenId    String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MemberProfile {
  id         String   @id @default(cuid())
  userId     String?  @unique
  name       String
  classYear  String?
  profession String?
  chapter    String?
  location   String?
  status     String   @default("Active")
  verified   Boolean  @default(false)
  joinedAt   DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Event {
  id          String           @id @default(cuid())
  title       String
  date        DateTime
  schedule    String?
  type        String?
  location    String?
  description String?
  status      RecordStatus     @default(ACTIVE)
  createdById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  createdBy User? @relation("EventCreator", fields: [createdById], references: [id], onDelete: SetNull)
  rsvps     EventRegistration[]

  @@index([date])
}

model EventRegistration {
  id         String   @id @default(cuid())
  eventId    String
  userId     String?
  guestName  String?
  guestEmail String?
  createdAt  DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([userId])
}

model Donation {
  id             String       @id @default(cuid())
  donorName      String
  classYear      String?
  amount         Decimal      @db.Decimal(12, 2)
  currency       String       @default("NGN")
  details        String?
  status         RecordStatus @default(ACTIVE)
  donatedAt      DateTime     @default(now())
  donorUserId    String?
  transactionRef String?      @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  donorUser User? @relation(fields: [donorUserId], references: [id], onDelete: SetNull)
}

model Grievance {
  id            String       @id @default(cuid())
  trackingId    String       @unique
  category      String
  message       String
  status        String       @default("Received")
  submittedById String?
  submittedAt   DateTime     @default(now())
  resolvedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  submittedBy User? @relation(fields: [submittedById], references: [id], onDelete: SetNull)
}

model WhistleReport {
  id          String   @id @default(cuid())
  trackingId  String   @unique
  note        String
  submittedAt DateTime @default(now())
  isAnonymous Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CareerOpportunity {
  id          String       @id @default(cuid())
  title       String
  company     String
  location    String?
  type        String?
  description String?
  status      RecordStatus @default(ACTIVE)
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  createdBy User? @relation("CareerCreator", fields: [createdById], references: [id], onDelete: SetNull)
}

model MentorProfile {
  id          String       @id @default(cuid())
  userId      String?      @unique
  name        String
  profession  String?
  company     String?
  expertise   String?
  bio         String?
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model MemberRegistration {
  id          String       @id @default(cuid())
  fullName    String
  email       String
  classYear   String?
  phone       String?
  chapter     String?
  profession  String?
  note        String?
  status      RecordStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([email])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  meta        Json?
  createdAt   DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
}
